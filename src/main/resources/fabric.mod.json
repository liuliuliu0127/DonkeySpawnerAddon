{
  "schemaVersion": 1,
  "id": "donkeyspawner-addon",
  "version": "${version}",
  "name": "DonkeySpawner Addon",
  "description": "An addon  for Meteor Client which added some features for servers like 2b2t.xin",
  "authors": [
    "liuliuliu0127",
    "Deepseek"
  ],
  "contact": {
    "sources": "https://github.com/liuliuliu0127/DonkeySpawnerAddon"
  },
  "icon": "assets/donkeyspawner/icon.png",
